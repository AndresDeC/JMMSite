---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
    title?: string;
}

const { title = "JM Monterrey | Misión Juvenil" } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    </head>
    <body class="antialiased">
        <Navbar />
        
        <main class="pt-20 min-h-screen">
            <slot />
        </main>

        <footer class="py-10 text-center text-sm opacity-60">
            <p>&copy; {new Date().getFullYear()} Juventud Masculina Monterrey</p>
        </footer>
    </body>
</html>

<style is:global>
  :root {
    /* FONDO: Un crema 'Arena' que quita todo el brillo del blanco */
    --jm-bg: #8de1ff; 
    
    /* PRIMARIO: Azul Oxford (más serio y profundo que el azul estándar) */
    --jm-blue: #002855; 
    
    /* ACENTO: Oro Viejo (menos brillante, más tirando a bronce elegante) */
    --jm-gold: #AD8B45; 
    
    /* TARJETAS: Blanco 'Hueso' para que resalten del fondo sin brillar */
    --jm-card: #FAF9F6;
    
    /* TEXTO: Un gris carbón para que no sea negro puro (más suave al leer) */
    --jm-text: #2D3436;
  }

  html, body {
    background-color: var(--jm-bg);
    color: var(--jm-text);
    font-family: 'Inter', system-ui, sans-serif;
  }

  /* Títulos con Serif para ese look de 'Institución/Herencia' */
  h1, h2, h3, .font-serif {
    font-family: 'Playfair Display', serif;
    color: var(--jm-blue);
    letter-spacing: -0.02em;
  }
</style>