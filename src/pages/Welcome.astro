---
import Layout from '../layouts/Layout.astro';

// Welcome.astro - Estructura original preservada
---

<Layout title="Schoenstatt Monterrey | Juventud Masculina">
    <div id="welcome-page-container">
        <div id="hero-background-fade"></div>

        <main id="welcome-main-content">
            <section id="hero">
                <div class="badge">Misión Juvenil Monterrey</div>
                <h1>
                    Schoenstatt Monterrey <br class="hidden-mobile" />
                    <span class="highlight">Juventud Masculina</span>
                </h1>
                <p class="subtitle">
                    Formando hombres nuevos en una nueva comunidad. Un camino de alianza desde el corazón de Monterrey.
                </p>

                <section id="links">
                    <a class="button primary" href="#santuario">Nuestra Espiritualidad</a>
                    <a class="button secondary" href="/capitalario">
                        Capitalario
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 5l7 7-7 7"></path>
                            <path d="M5 12h14"></path>
                        </svg>
                    </a>
                </section>
            </section>

            <aside id="quote-box" class="box">
                <div class="quote-header">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="var(--jm-gold)"></path>
                    </svg>
                    <h2>Seguro de Victoria</h2>
                </div>
                <p>
                    "Nada sin ti, nada sin nosotros". Un camino de alianza para la juventud de hoy que busca transformar el mundo.
                </p>
            </aside>
        </main>
    </div>
</Layout>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
</style>
