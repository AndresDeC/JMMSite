---
// src/components/Navbar.astro
const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Misión', href: '/mision' },
  { name: 'Santuario', href: '#santuario' },
  { name: 'Capitalario', href: '/capitalario', highlight: true },
  { name: 'Casa JM', href: '/casajm', highlight: true }
];
---

<nav class="fixed top-6 left-1/2 -translate-x-1/2 w-[95%] max-w-7xl z-50 transition-all duration-500" id="main-nav">
  <div class="bg-white/70 backdrop-blur-2xl border border-white/30 shadow-[0_8px_32px_0_rgba(0,0,0,0.1)] rounded-3xl px-6 py-3">
    <div class="flex justify-between items-center">
      
      <a href="/" class="flex items-center gap-3 no-underline group">
        <div class="w-11 h-11 bg-gradient-to-br from-[#003366] to-[#0055aa] rounded-2xl flex items-center justify-center transition-all duration-500 group-hover:rotate-[10deg] group-hover:shadow-lg group-hover:shadow-blue-500/30">
          <span class="text-[#ffcc00] font-black text-xs tracking-tighter">JM</span>
        </div>
        <div class="flex flex-col">
          <span class="text-[#003366] font-black text-lg leading-none tracking-tight">Monterrey</span>
          <span class="text-[#59bdff] text-[10px] font-bold uppercase tracking-[0.2em]">Juventud Masculina</span>
        </div>
      </a>

      <div class="hidden md:flex items-center space-x-1">
        {navItems.map(item => (
          <a 
            href={item.href}
            class={`px-5 py-2.5 text-sm font-bold transition-all duration-300 rounded-2xl no-underline relative group ${
              item.highlight 
              ? 'bg-[#003366] text-white hover:bg-[#ffcc00] hover:text-[#003366] ml-2 shadow-lg shadow-blue-900/10 hover:-translate-y-0.5' 
              : 'text-[#003366]/70 hover:text-[#003366] hover:bg-blue-50/50'
            }`}
          >
            {item.name}
            {!item.highlight && (
              <span class="absolute bottom-2 left-1/2 -translate-x-1/2 w-0 h-0.5 bg-[#ffcc00] transition-all duration-300 group-hover:w-4"></span>
            )}
          </a>
        ))}
      </div>

      <div class="md:hidden">
        <button id="menu-btn" class="p-2 text-[#003366] hover:bg-blue-50 rounded-xl transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden absolute top-20 left-0 w-full bg-white/95 backdrop-blur-xl border border-white/20 rounded-3xl p-6 shadow-2xl space-y-4">
    {navItems.map(item => (
      <a 
        href={item.href} 
        class={`block p-4 rounded-2xl text-lg font-bold no-underline transition-all ${
          item.highlight 
          ? 'bg-[#003366] text-white shadow-lg' 
          : 'text-[#003366] hover:bg-blue-50'
        }`}
      >
        {item.name}
      </a>
    ))}
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const nav = document.getElementById('main-nav');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      // En lugar de escalar, solo ajustamos la posición y el brillo
      nav?.classList.add('top-2');
      nav?.querySelector('div')?.classList.add('shadow-2xl');
    } else {
      nav?.classList.remove('top-2');
      nav?.querySelector('div')?.classList.remove('shadow-2xl');
    }
  });
</script>

<style>
  /* Fuente Serif opcional para Monterrey si quieres ese look elegante */
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap');
  
  :root {
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
</style>