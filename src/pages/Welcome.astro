---
import Layout from '../layouts/Layout.astro';

// Welcome.astro - Ahora como página principal
---

<Layout title="Schoenstatt Monterrey | Juventud Masculina">
	<div id="container">
		<div id="background-overlay"></div>

		<main>
			<section id="hero">
				<div class="badge">Misión Juvenil Monterrey</div>
				<h1>
					Schoenstatt Monterrey <br class="hidden-mobile" />
					<span class="highlight">Juventud Masculina</span>
				</h1>
				<p class="subtitle">
					Formando hombres nuevos en una nueva comunidad. Un camino de alianza desde el corazón de Monterrey.
				</p>

				<section id="links">
					<a class="button primary" href="#santuario">Nuestra Espiritualidad</a>
					<a class="button secondary" href="/capitalario">
						Capitalario
						<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 5l7 7-7 7"></path>
							<path d="M5 12h14"></path>
						</svg>
					</a>
				</section>
			</section>

			<aside id="quote-box" class="box">
				<div class="quote-header">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="var(--jm-gold)"></path>
					</svg>
					<h2>Seguro de Victoria</h2>
				</div>
				<p>
					"Nada sin ti, nada sin nosotros". Un camino de alianza para la juventud de hoy que busca transformar el mundo.
				</p>
			</aside>
		</main>
	</div>
</Layout>

<style>
	/* VARIABLES DE MARCA */
	:root {
		--jm-blue: #003876;
		--jm-gold: #AD8B45;
		--jm-bg: #F2EFE9;
		--jm-card: #FAF9F6;
		--jm-text: #2D3436;
	}

	#container {
		font-family: 'Inter', system-ui, sans-serif;
		min-height: 100vh;
		background-color: var(--jm-bg);
		color: var(--jm-text);
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		overflow-x: hidden;
		padding: 4rem 0; /* Un poco más de espacio para el Navbar */
	}

	#background-overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle at top right, rgba(173, 139, 69, 0.08), transparent),
					radial-gradient(circle at bottom left, rgba(0, 56, 118, 0.04), transparent);
		z-index: 0;
	}

	main {
		position: relative;
		z-index: 1;
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem;
		display: grid;
		grid-template-columns: 1fr 380px;
		gap: 4rem;
		align-items: center;
	}

	#hero {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.badge {
		background: rgba(0, 56, 118, 0.06);
		color: var(--jm-blue);
		padding: 6px 16px;
		border-radius: 99px;
		font-weight: 700;
		font-size: 0.7rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		width: fit-content;
	}

	h1 {
		font-family: 'Playfair Display', serif;
		font-size: clamp(2.2rem, 7vw, 4.2rem);
		line-height: 1.05;
		margin: 0;
		font-weight: 800;
		color: var(--jm-blue);
		letter-spacing: -0.02em;
	}

	.highlight {
		color: var(--jm-gold);
		font-style: normal;
	}

	.subtitle {
		font-size: clamp(1rem, 2vw, 1.25rem);
		color: #555;
		max-width: 550px;
		margin: 0;
		line-height: 1.6;
	}

	#links {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}

	.button {
		padding: 14px 28px;
		border-radius: 12px;
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: all 0.3s ease;
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.button.primary {
		background: var(--jm-blue);
		color: white;
		box-shadow: 0 10px 20px rgba(0, 56, 118, 0.15);
	}

	.button.secondary {
		background: transparent;
		border: 2px solid var(--jm-blue);
		color: var(--jm-blue);
	}

	.button:hover {
		transform: translateY(-3px);
		filter: brightness(1.1);
	}

	.box {
		background: var(--jm-card);
		padding: 2.5rem;
		border-radius: 28px;
		border: 1px solid rgba(173, 139, 69, 0.2);
		box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
	}

	.quote-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	#quote-box h2 {
		font-size: 1rem;
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-weight: 800;
		color: var(--jm-blue);
	}

	#quote-box p {
		font-style: normal; /* Quitamos itálica como querías */
		font-size: 0.95rem;
		line-height: 1.6;
		color: #666;
		margin: 0;
	}

	/* RESPONSIVIDAD MAESTRA */
	@media (max-width: 1024px) {
		main {
			grid-template-columns: 1fr;
			gap: 3rem;
			padding: 3rem 1.5rem;
		}

		#hero {
			align-items: center;
			text-align: center;
		}

		.badge {
			margin: 0 auto;
		}

		#links {
			flex-direction: column;
			width: 100%;
		}

		.button {
			justify-content: center;
			width: 100%;
		}

		#quote-box {
			width: 100%;
			max-width: 450px;
			margin: 0 auto;
		}

		.hidden-mobile {
			display: none;
		}
	}

	@media (max-width: 380px) {
		h1 {
			font-size: 1.8rem;
		}
		.box {
			padding: 1.5rem;
		}
	}
</style>