---
const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Misión', href: '#mision' },
  { name: 'Santuario', href: '#santuario' },
  { name: 'Capitalario', href: '#capitalario', highlight: true },
];
---

<nav class="fixed w-full z-50 bg-[#FDFCF8]/90 backdrop-blur-md border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20 items-center">
      
      <div class="flex-shrink-0 flex items-center gap-2">
        <div class="w-10 h-10 bg-[#003876] rounded-full flex items-center justify-center">
          <span class="text-[#C5A059] font-bold">JM</span>
        </div>
        <span class="text-[#003876] font-serif text-xl font-bold tracking-tight">
          Monterrey
        </span>
      </div>

      <div class="hidden md:flex items-center space-x-8">
        {navItems.map(item => (
          <a 
            href={item.href}
            class={`text-sm font-medium transition-colors duration-300 ${
              item.highlight 
              ? 'bg-[#003876] text-white px-5 py-2 rounded-full hover:bg-[#C5A059] hover:text-[#003876]' 
              : 'text-[#1a1a1a] hover:text-[#C5A059]'
            }`}
          >
            {item.name}
          </a>
        ))}
      </div>

      <div class="md:hidden flex items-center">
        <button id="menu-btn" class="text-[#003876] p-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-[#FDFCF8] border-b border-gray-100 px-4 py-6 space-y-4 shadow-xl">
    {navItems.map(item => (
      <a 
        href={item.href} 
        class="block text-lg font-medium text-[#1a1a1a] hover:text-[#C5A059]"
      >
        {item.name}
      </a>
    ))}
  </div>
</nav>

<script>
  // Lógica simple para el menú móvil
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>