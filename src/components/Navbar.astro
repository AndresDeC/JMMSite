---
// src/components/Navbar.astro
const navItems = [
  { name: 'Inicio', href: '/' },
  { name: 'Misión', href: '/mision' }, // Asegúrate de crear mision.astro en /pages
  { name: 'Santuario', href: '#santuario' },
  { name: 'Capitalario', href: '/capitalario', highlight: true },
  {name: 'Casa JM', href: '/casajm', highlight: true}
];
---

<nav class="fixed top-0 w-full z-50 bg-[#FDFCF8]/90 backdrop-blur-md border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20 items-center">
      
      <a href="/" class="flex items-center gap-2 no-underline group">
        <div class="w-10 h-10 bg-[#003876] rounded-full flex items-center justify-center transition-transform group-hover:scale-110">
          <span class="text-[#C5A059] font-bold text-sm">JM</span>
        </div>
        <span class="text-[#003876] font-serif text-xl font-bold tracking-tight">
          Monterrey
        </span>
      </a>

      <div class="hidden md:flex items-center space-x-8">
        {navItems.map(item => (
          <a 
            href={item.href}
            class={`text-sm font-semibold transition-all duration-300 no-underline ${
              item.highlight 
              ? 'bg-[#003876] text-white px-6 py-2.5 rounded-full hover:bg-[#C5A059] hover:text-[#003876] shadow-md shadow-[#003876]/20' 
              : 'text-[#1a1a1a] hover:text-[#C5A059]'
            }`}
          >
            {item.name}
          </a>
        ))}
      </div>

      <div class="md:hidden flex items-center">
        <button id="menu-btn" class="text-[#003876] p-2 focus:outline-none">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-[#FDFCF8] border-b border-gray-100 px-6 py-8 space-y-6 shadow-2xl">
    {navItems.map(item => (
      <a 
        href={item.href} 
        class={`block text-lg font-medium no-underline ${
          item.highlight ? 'text-[#C5A059] font-bold' : 'text-[#1a1a1a]'
        }`}
      >
        {item.name}
      </a>
    ))}
  </div>
</nav>

<script>
  // Lógica del menú móvil (se ejecuta solo en el cliente)
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    // Animación simple de entrada
    if (!menu?.classList.contains('hidden')) {
      menu.animate([
        { opacity: 0, transform: 'translateY(-10px)' },
        { opacity: 1, transform: 'translateY(0)' }
      ], { duration: 300, easing: 'ease-out' });
    }
  });

  // Cerrar menú al hacer click en un link (útil para anchors #)
  const links = document.querySelectorAll('#mobile-menu a');
  links.forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
    });
  });
</script>

<style>
  /* Evitar que los enlaces tengan el subrayado azul por defecto si Tailwind no carga */
  a {
    text-decoration: none;
  }
</style>