---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';

// Importación de imágenes (Asegúrate que existan en src/assets/)
import fotoAvance from '../assets/casa-construccion-1.jpeg';
import fotoEquipo from '../assets/casa-construccion-2.jpeg';
import fotoConstruccion from '../assets/casa-construccion.jpeg';

const avances = [
  {
    fecha: 'Marzo 2026',
    titulo: 'Instalaciones Eléctricas',
    desc: 'Comenzamos con el cableado inteligente que conectará el Capitalario físico con el sistema central.',
  },
  {
    fecha: 'Enero 2026',
    titulo: 'Estructura Principal',
    desc: 'Se finalizó con éxito el techado del salón de usos múltiples y áreas comunes.',
  }
];
---

<Layout title="Nuestra Casa JM | Monterrey">
  <section class="relative h-[70vh] flex items-center justify-center overflow-hidden bg-[#003876]">
    <div class="absolute inset-0 z-0">
      <Image 
        src={fotoConstruccion} 
        alt="Progreso de la obra" 
        class="w-full h-full object-cover opacity-40"
        loading="eager"
      />
    </div>
    
    <div class="relative z-10 text-center px-6">
      <span class="text-[#C5A059] font-bold tracking-[0.3em] uppercase text-sm">Sede Monterrey</span>
      <h1 class="text-6xl md:text-8xl text-white font-serif mt-4 tracking-tighter">
        Casa <span class="italic text-[#C5A059]">JM</span>
      </h1>
      <p class="text-white/90 max-w-xl mx-auto mt-6 text-lg font-light">
        Más que paredes, estamos construyendo el hogar para las futuras generaciones de la Juventud Masculina.
      </p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 -mt-20 relative z-20">
    <div class="bg-white rounded-[2.5rem] shadow-2xl p-8 md:p-12 border border-slate-100 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-3xl font-serif text-[#003876] mb-4">Suma tu ladrillo</h2>
        <p class="text-slate-600 mb-8 leading-relaxed">
          La Casa JM se construye gracias a la generosidad de aliados como tú. Cada donativo directo se destina íntegramente a los materiales de construcción.
        </p>
        <a href="/donar" class="inline-block bg-[#C5A059] text-[#003876] font-bold px-10 py-4 rounded-full text-center hover:bg-[#003876] hover:text-white transition-all no-underline shadow-xl shadow-[#C5A059]/20">
          Donar ahora
        </a>
      </div>
      
      <div class="bg-[#FDFCF8] p-8 rounded-3xl border border-[#C5A059]/20">
        <div class="flex justify-between mb-3 font-bold text-[#003876] text-sm uppercase tracking-wider">
          <span>Meta de Construcción</span>
          <span>75%</span>
        </div>
        <div class="w-full bg-slate-200 rounded-full h-4 overflow-hidden shadow-inner">
          <div class="bg-[#C5A059] h-full rounded-full" style="width: 75%"></div>
        </div>
        <p class="text-xs text-slate-500 mt-6 text-center italic font-medium">
          "Nada sin Ti, nada sin nosotros."
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto py-24 px-6">
    <div class="text-center mb-16">
      <h2 class="text-4xl font-serif text-[#003876] italic underline decoration-[#C5A059]/30 underline-offset-8">Testigos del crecimiento</h2>
    </div>
    
    <div class="grid md:grid-cols-2 gap-12">
      <div class="group">
        <div class="overflow-hidden rounded-3xl shadow-lg aspect-[16/10] mb-6 border border-slate-100 bg-slate-200">
          <Image 
            src={fotoAvance} 
            alt="Detalle de avance" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
          />
        </div>
        <h3 class="text-2xl font-serif text-[#003876] font-bold mb-2">Cuidando cada detalle</h3>
        <p class="text-slate-600 leading-relaxed">Supervisión constante para asegurar que nuestra casa sea un lugar seguro y funcional.</p>
      </div>

      <div class="group md:mt-24">
        <div class="overflow-hidden rounded-3xl shadow-lg aspect-[16/10] mb-6 border border-slate-100 bg-slate-200">
          <Image 
            src={fotoEquipo} 
            alt="Equipo de trabajo" 
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
          />
        </div>
        <h3 class="text-2xl font-serif text-[#003876] font-bold mb-2">Comunidad en acción</h3>
        <p class="text-slate-600 leading-relaxed">No solo es una obra civil; es una familia trabajando unida por un ideal común.</p>
      </div>
    </div>
  </section>

  <section class="bg-slate-50 py-24 border-y border-slate-200">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-4xl font-serif text-[#003876] mb-12">Bitácora de Obra</h2>
      <div class="space-y-8 text-left">
        {avances.map((item) => (
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
            <div class="flex justify-between items-center mb-2">
              <h4 class="font-bold text-[#003876] text-xl">{item.titulo}</h4>
              <span class="text-xs font-bold text-[#C5A059] bg-[#C5A059]/10 px-2 py-1 rounded">{item.fecha}</span>
            </div>
            <p class="text-slate-500">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <footer class="py-12 text-center bg-[#003876] text-white/60 text-xs tracking-widest uppercase">
    Juventud Masculina Monterrey © 2026
  </footer>
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>