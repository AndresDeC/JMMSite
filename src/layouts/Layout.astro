---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
    title?: string;
}

const { title = "JM Monterrey | Misión Juvenil" } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    </head>
    <body class="antialiased">
        <Navbar />
        
        <main class="pt-20 min-h-screen">
            <slot />
        </main>

        <footer class="py-10 text-center text-sm opacity-60">
            <p>&copy; {new Date().getFullYear()} Juventud Masculina Monterrey</p>
        </footer>
    </body>
</html>

<style is:global>
	:root {
		/* Paleta Global Mate */
		--jm-bg: #F2EFE9; 
		--jm-blue: #002855;
		--jm-gold: #AD8B45;
		--jm-card: #FAF9F6;
		--jm-text: #2D3436;
	}

	html {
		background-color: var(--jm-bg);
		/* Evita que el texto cambie de tamaño al girar el móvil */
		-webkit-text-size-adjust: 100%;
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		padding: 0;
		color: var(--jm-text);
		font-family: 'Inter', system-ui, sans-serif;
		overflow-x: hidden; /* Vital para que nada "baile" en móvil */
	}
  /* Fuerza al Navbar a ignorar el área de scroll del cuerpo */
  nav#main-nav {
    pointer-events: auto !important;
    touch-action: manipulation; /* Optimiza para toques rápidos en cel */
  }

  /* Asegura que el slot (el contenido) no se encime */
  main {
    position: relative;
    z-index: 1;
  }

	/* --- SOLUCIÓN GLOBAL DE BRILLO --- */
	
  /* Esto cambia CUALQUIER fondo blanco por el tono arena suave */
  .bg-white, [class*="bg-white"] {
    background-color: #F2EFE9 !important;
  }

  /* Baja el brillo de todas las fotos un 10% para que no 'salten' del fondo mate */
  img {
    filter: brightness(0.9) contrast(1.05);
  }

  /* Margen de seguridad para que el texto no toque los bordes del celular */
  body {
    background-color: #F2EFE9;
    padding-left: env(safe-area-inset-left);
    padding-right: env(safe-area-inset-right);
  }

	/* --- SOLUCIÓN GLOBAL DE MÓVIL --- */

h1 { 
  /* Mínimo 2.5rem, ideal 8vw, máximo 6rem */
  font-size: clamp(2.5rem, 8vw, 6rem) !important; 
  line-height: 1.1;
}

h2 { 
  font-size: clamp(1.8rem, 5vw, 3.5rem) !important; 
}

	/* 4. Contenedores seguros para celular */
	.container-jm {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem; /* Margen de seguridad en móviles */
	}

	/* 5. Ajuste de espaciados (márgenes grandes en PC, pequeños en móvil) */
    @media (max-width: 768px) {
      /* Forzamos que cualquier sección tenga un margen interno lateral */
      section {
        padding-left: 1.5rem !important;
        padding-right: 1.5rem !important;
      }
      
      /* Evitamos que las tarjetas encimadas (-mt-20) se vean mal en pantallas cortas */
      [class*="-mt-"] {
        margin-top: -2.5rem !important;
      }

		/* Forzamos que los grids de 2 o más columnas se vuelvan de 1 */
		.grid-cols-2, .grid-cols-3, .grid-cols-4 {
			grid-template-columns: repeat(1, minmax(0, 1fr)) !important;
			gap: 2rem !important;
		}
	}

	/* --- CLASES DE ESTILO REUTILIZABLES --- */
	.font-serif { font-family: 'Playfair Display', serif; }
	.text-jm-blue { color: var(--jm-blue); }
	.text-jm-gold { color: var(--jm-gold); }

</style>