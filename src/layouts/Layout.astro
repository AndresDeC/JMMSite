---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';

interface Props {
    title?: string;
}

const { title = "JM Monterrey | Misión Juvenil" } = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    </head>
    <body class="antialiased">
        <Navbar />
        
        <main class="pt-20 min-h-screen">
            <slot />
        </main>

        <footer class="py-10 text-center text-sm opacity-60">
            <p>&copy; {new Date().getFullYear()} Juventud Masculina Monterrey</p>
        </footer>
    </body>
</html>

<style is:global>
	:root {
		/* Paleta Global Mate */
		--jm-bg: #F2EFE9; 
		--jm-blue: #002855;
		--jm-gold: #AD8B45;
		--jm-card: #FAF9F6;
		--jm-text: #2D3436;
	}

	html {
		background-color: var(--jm-bg);
		/* Evita que el texto cambie de tamaño al girar el móvil */
		-webkit-text-size-adjust: 100%;
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		padding: 0;
		color: var(--jm-text);
		font-family: 'Inter', system-ui, sans-serif;
		overflow-x: hidden; /* Vital para que nada "baile" en móvil */
	}

	/* --- SOLUCIÓN GLOBAL DE BRILLO --- */
	
	/* 1. Suavizamos todas las secciones blancas */
	.bg-white, section[class*="bg-white"] {
		background-color: var(--jm-card) !important;
	}

	/* 2. Filtro global para imágenes (baja el brillo 10%) */
	img {
		filter: brightness(0.9) contrast(1.05);
		max-width: 100%;
		height: auto;
	}

	/* --- SOLUCIÓN GLOBAL DE MÓVIL --- */

	/* 3. Tipografía responsiva automática */
	h1 { font-size: clamp(2.5rem, 8vw, 6rem); }
	h2 { font-size: clamp(1.8rem, 5vw, 3.5rem); }
	h3 { font-size: clamp(1.4rem, 3vw, 2rem); }

	/* 4. Contenedores seguros para celular */
	.container-jm {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1.5rem; /* Margen de seguridad en móviles */
	}

	/* 5. Ajuste de espaciados (márgenes grandes en PC, pequeños en móvil) */
	@media (max-width: 768px) {
		section {
			padding-top: 3rem !important;
			padding-bottom: 3rem !important;
		}
		
		/* Si usas márgenes negativos para encimar tarjetas, los bajamos en móvil */
		[class*="-mt-"] {
			margin-top: -2rem !important;
		}

		/* Forzamos que los grids de 2 o más columnas se vuelvan de 1 */
		.grid-cols-2, .grid-cols-3, .grid-cols-4 {
			grid-template-columns: repeat(1, minmax(0, 1fr)) !important;
			gap: 2rem !important;
		}
	}

	/* --- CLASES DE ESTILO REUTILIZABLES --- */
	.font-serif { font-family: 'Playfair Display', serif; }
	.text-jm-blue { color: var(--jm-blue); }
	.text-jm-gold { color: var(--jm-gold); }

</style>