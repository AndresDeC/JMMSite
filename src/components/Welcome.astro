---
// Importamos solo lo necesario. 
// Nota: Asegúrate de tener una imagen del Santuario o de la JM en src/assets/
---

<div id="container">
    <div id="background-overlay"></div>
    
    <main>
        <section id="hero">
            <div class="badge">Misión Juvenil Monterrey</div>
            <h1>
                Texto
            </h1>
            <p class="subtitle">Texto</p>
            
            <section id="links">
                <a class="button primary" href="#santuario">Nuestra Espiritualidad</a>
                <a class="button secondary" href="/capitalario">
                    Capitalario
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5l7 7-7 7"></path><path d="M5 12h14"></path></svg>
                </a>
            </section>
        </section>
    </main>

    <div id="quote-box" class="box">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" fill="#C5A059"></path>
        </svg>
        <h2>Seguro de Victoria</h2>
        <p>
            "Nada sin ti, nada sin nosotros". Un camino de alianza para la juventud de hoy.
        </p>
    </div>
</div>

<style>
    /* Colores Oficiales */
    :root {
        --jm-blue: #003876;
        --jm-gold: #C5A059;
        --jm-white: #FDFCF8;
        --jm-dark: #1a1a1a;
    }

    #container {
        font-family: 'Inter', system-ui, sans-serif;
        height: 100vh;
        background-color: var(--jm-white);
        color: var(--jm-dark);
        display: flex;
        align-items: center;
        overflow: hidden;
    }

    #background-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: radial-gradient(circle at top right, rgba(197, 160, 89, 0.1), transparent),
                    radial-gradient(circle at bottom left, rgba(0, 56, 118, 0.05), transparent);
        z-index: -1;
    }

    main {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    #hero {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.5rem;
    }

    .badge {
        background: rgba(0, 56, 118, 0.1);
        color: var(--jm-blue);
        padding: 6px 16px;
        border-radius: 99px;
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    h1 {
        font-family: 'Playfair Display', serif; /* Asegúrate de cargarla en el Layout */
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        line-height: 1.1;
        margin: 0;
        font-weight: 800;
        color: var(--jm-blue);
    }

    .highlight {
        color: var(--jm-gold);
        font-style: italic;
    }

    .subtitle {
        font-size: 1.25rem;
        color: #666;
        max-width: 600px;
        margin: 0;
    }

    #links {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
    }

    .button {
        padding: 12px 28px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .button.primary {
        background: var(--jm-blue);
        color: white;
    }

    .button.secondary {
        border: 2px solid var(--jm-blue);
        color: var(--jm-blue);
    }

    .button:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 56, 118, 0.15);
    }

    .box {
        background: white;
        padding: 24px;
        border-radius: 20px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    #quote-box {
        position: absolute;
        bottom: 40px;
        right: 40px;
        max-width: 320px;
    }

    h2 {
        font-size: 1.25rem;
        margin: 0.5rem 0;
        color: var(--jm-blue);
    }

    p {
        font-size: 0.95rem;
        line-height: 1.6;
        color: #555;
    }

    @media (max-width: 768px) {
        #container {
            height: auto;
            padding: 100px 0;
        }
        #quote-box {
            position: relative;
            bottom: 0;
            right: 0;
            margin: 2rem;
            max-width: none;
        }
        #links {
            flex-direction: column;
            width: 100%;
        }
        .button {
            justify-content: center;
        }
    }
</style>